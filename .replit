modules = ["nodejs-20"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm run dev"
waitForPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 3000
externalPort = 3000

[userenv]

[userenv.shared]
PORT = "3000"
NODE_ENV = "development"
JWT_EXPIRE = "30d"
WHATSAPP_NUMBER = "917000000000"
FRONTEND_URL = "http://localhost:5000"
MAX_FILE_SIZE = "5242880"
UPLOAD_PATH = "./uploads"
EMAIL_HOST = "smtp.gmail.com"
EMAIL_PORT = "587"
EMAIL_FROM = "Yashraj Palace <noreply@yashrajpalace.com>"
